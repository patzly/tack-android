  <!-- MESSAGES -->

  <string name="msg_feedback">Разработка хорошего приложения занимает много времени и зависит от обратной связи пользователей</string>
  <string name="msg_feedback_contact">У вас есть пожелания, комментарии или вопросы? Свяжитесь со мной! В противном случае я буду очень рад положительному отзыву в Play Store.</string>
  <string name="msg_recommend">Зацени классный метроном: \n%1$s</string>
  <string name="msg_vibration_unavailable">На этом устройстве недоступна функция вибрации. Будет использоваться только звук.</string>
  <string name="msg_service_running">Сервис метронома запущен</string>
  <string name="msg_service_running_return">Нажмите, чтобы вернуться в Tack</string>
  <string name="msg_service_description">Сервис для настройки и проигрывания метронома</string>
  <string name="msg_reset">Сбросить всё?</string>
  <string name="msg_reset_description">Вы действительно хотите сбросить приложение, включая библиотеку песен и настройки? Если вам нужен бэкап, сначала создайте его - сброс невозможно отменить.</string>
  <string name="msg_reset_timer">Сбросить таймер?</string>
  <string name="msg_reset_timer_description">Вы можете указать в настройках, нужно ли сбрасывать таймер при запуске.</string>
  <string name="msg_reset_elapsed">Сбросить затраченное время?</string>
  <string name="msg_reset_elapsed_description">Вы действительно хотите сбросить затраченное время? Это действие нельзя отменить.</string>
  <string name="msg_gain">Включить усиление громкости?</string>
  <string name="msg_gain_description">Будьте осторожны и не слушайте метроном в наушниках, так как громкие звуки могут вызвать потерю слуха!</string>
  <string name="msg_split_screen">Окно слишком маленькое</string>
  <string name="msg_split_screen_description">В режиме разделённого экрана, некоторые элементы управления Tack могут отображаться некорректно. Если это возможно, увеличьте размер окна.</string>
  <string name="msg_notification_permission">Требуется разрешение для показа уведомлений</string>
  <string name="msg_notification_permission_description">Tack запрашивает разрешение для показа уведомлений, чтобы продолжить воспроизведение в фоновом режиме, отображая уведомление с низким приоритетом. Если вы откажетесь от этого в следующем диалоговом окне, Android остановит воспроизведение, когда вы выйдете из приложения.</string>
  <string name="msg_notification_permission_denied">Для фонового воспроизведения требуется разрешение на отправку уведомлений</string>
  <string name="msg_report_crash">Пожалуйста сообщайте о каждом вылете, прикрепляя логи. Так я смогу это исправить.</string>
  <string name="msg_copied_to_clipboard">Успешно скопировано в буфер обмена</string>
  <string name="msg_invalid_input">Неправильный ввод</string>
  <string name="msg_discard_changes">Отменить изменения?</string>
  <string name="msg_discard_changes_description">Вы уверены, что не хотите сохранить изменения?</string>
  <string name="msg_delete_song">Удалить песню?</string>
  <string name="msg_delete_song_description">Вы действительно уверены, что хотите удалить песню целиком, включая все её части? Это действие нельзя отменить.</string>
  <string name="msg_songs_empty">Библиотека песен пуста</string>
  <string name="msg_songs_empty_description">Добавьте песни, которые вы хотите играть</string>
  <string name="msg_unlock">Сообщение от разработчика</string>
  <string name="msg_unlock_description">Вам нравится, что в Tack нет рекламы, но при этом есть множество мощных функций? Я потратил годы своего свободного времени на создание Tack, но особенно много сил ушло на создание библиотеки песен. Чтобы продолжать улучшать Tack, я прошу вас сделать небольшое пожертвование. Взамен вы получите приложение для разблокировки неограниченного количества песен и их фрагментов. Спасибо за вашу поддержку!</string>
  <string name="msg_backup_description">Вы можете создать резервную копию всей своей музыкальной библиотеки на устройстве или восстановить ее из резервной копии.</string>
  <string name="msg_backup_error">Ошибка при создании бэкапа</string>
  <string name="msg_backup_directory_missing">Не задан путь к бэкапу в хранилище</string>
  <string name="msg_backup_success">Бэкап успешно создан</string>
  <string name="msg_restore_error">Ошибка при восстановлении бэкапа</string>
  <string name="msg_restore_file_missing">Не был выбран файл для восстановления</string>
  <string name="msg_restore_success">Бэкап успешно восстановлен</string>
  <!-- Name of a song after restoring a backup when a song with the name already exists. E.g. "Song name (1)" -->
  <string name="msg_restore_duplicate_name">%1$s (%2$d)</string>
  <string name="msg_songs_intro">Как работает библиотека песен</string>
  <string name="msg_songs_intro_description">Вы можете сохранять и упорядочивать настройки метронома как части композиции. Просто настройте метроном по своему усмотрению, а затем добавьте текущую настройку в качестве новой части композиции или отредактируйте существующую.</string>
  <string name="msg_widget_description">Просматривайте свои песни и включайте их</string>
  <string name="msg_widget_prompt">Быстрый доступ к песням?</string>
  <string name="msg_widget_prompt_description">Разместите красивый виджет на рабочем столе.</string>
  <string name="msg_beat_mode_warning">Переключить режим воспроизведения ритма в режим только звука?</string>

