  <!-- MESSAGES -->

  <string name="msg_feedback">Una grande app richiede molto tempo e vive grazie ai feedback dei suoi utenti.</string>
  <string name="msg_feedback_contact">Hai suggerimenti, osservazioni o domande da condividere? Contattami! Altrimenti, mi farebbe molto piacere una buona recensione nel Play Store.</string>
  <string name="msg_recommend">Dai un\'occhiata a questa fantastica app metronomo: \n%1$s</string>
  <string name="msg_vibration_unavailable">La vibrazione non è disponibile su questo dispositivo. Verranno usati i suoni. </string>
  <string name="msg_service_running">Il servizio metronomo è in esecuzione</string>
  <string name="msg_service_running_return">Tocca per tornare a Tack</string>
  <string name="msg_service_description">Servizio per la configurazione e riproduzione del metronomo</string>
  <string name="msg_reset">Ripristinare tutto?</string>
  <string name="msg_reset_description">Vuoi davvero reimpostare l’intera app, inclusi libreria musicale e impostazioni? Se necessario, crea prima un backup della tua libreria musicale. Il ripristino non può essere annullato.</string>
  <string name="msg_reset_timer">Vuoi azzerare il timer?</string>
  <string name="msg_reset_timer_description">Puoi modificare nelle impostazioni il comportamento predefinito relativo all\'azzeramento del timer all’avvio.</string>
  <string name="msg_reset_elapsed">Azzerare il tempo trascorso?</string>
  <string name="msg_reset_elapsed_description">Vuoi davvero azzerare il tempo trascorso? Questa azione non può essere annullata.</string>
  <string name="msg_gain">Riprodurre con aumento del volume?</string>
  <string name="msg_gain_description">Presta attenzione a non riprodurre attraverso le cuffie, in quanto suoni forti possono causare danni alle orecchie!</string>
  <string name="msg_split_screen">La finestra è troppo piccola</string>
  <string name="msg_split_screen_description">Tack potrebbe avere problemi a posizionare i controlli del metronomo in modalità schermo diviso. Se possibile utilizza una finestra più grande.</string>
  <string name="msg_notification_permission">Autorizzazione notifiche necessaria</string>
  <string name="msg_notification_permission_description">Tack richiede l\'autorizzazione per mostrare le notifiche in modo da continuare la riproduzione in background mostrando una notifica a bassa priorità. Se nella prossima finestra di dialogo rifiuti il consenso, il sistema interromperà la riproduzione quando esci dall\'app.</string>
  <string name="msg_notification_permission_denied">Autorizzazione notifiche necessaria per riprodurre in background</string>
  <string name="msg_report_crash">Per favore segnala qualsiasi arresto anomalo allegando il relativo registro, così posso provare a risolverlo.</string>
  <string name="msg_copied_to_clipboard">Copiato negli appunti con successo</string>
  <string name="msg_invalid_input">Input non valido</string>
  <string name="msg_discard_changes">Annullare le modifiche?</string>
  <string name="msg_discard_changes_description">Sei sicuro di non volerle salvare?</string>
  <string name="msg_delete_song">Cancellare la canzone?</string>
  <string name="msg_delete_song_description">Sei sicuro di voler cancellare l\'intera canzone con tutte le sue sezioni? Questa azione non può essere annullata.</string>
  <string name="msg_songs_empty">La libreria di canzoni è vuota</string>
  <string name="msg_songs_empty_description">Aggiungi canzoni per studiare</string>
  <string name="msg_unlock">Messaggio dallo sviluppatore</string>
  <string name="msg_unlock_description">Ti piace l’esperienza senza pubblicità e con tutte le potenti funzionalità di Tack? Ho dedicato anni del mio tempo libero per creare Tack gratuitamente, ma in particolare la funzione della libreria di canzoni ha richiesto mesi di duro lavoro. Per poter continuare a migliorare Tack, ti chiedo gentilmente un piccolo contributo. In cambio otterrai un’app sbloccata con canzoni illimitate e un numero infinito di sezioni. Grazie per il tuo supporto!</string>
  <string name="msg_backup_description">Puoi salvare un backup della tua libreria di canzoni sul tuo dispositivo o ripristinare una libreria da un file di backup.</string>
  <string name="msg_backup_error">Errore durante il backup</string>
  <string name="msg_backup_directory_missing">Nessuna cartella di archiviazione selezionata per il backup</string>
  <string name="msg_backup_success">Backup creato con successo</string>
  <string name="msg_restore_error">Errore durante il ripristino del backup</string>
  <string name="msg_restore_file_missing">Nessun file selezionato per il ripristino</string>
  <string name="msg_restore_success">Backup ripristinato con successo</string>
  <!-- Name of a song after restoring a backup when a song with the name already exists. E.g. "Song name (1)" -->
  <string name="msg_restore_duplicate_name">%1$s (%2$d)</string>
  <string name="msg_songs_intro">Come funziona la libreria di canzoni</string>
  <string name="msg_songs_intro_description">Puoi salvare e organizzare le configurazioni del metronomo come sezioni di una canzone. Imposta i controlli e le opzioni del metronomo come preferisci, quindi aggiungi la configurazione attuale come nuova sezione di una canzone oppure modifica una sezione esistente.</string>
  <string name="msg_widget_description">Visualizza le tue canzoni e riproducile</string>
  <string name="msg_widget_prompt">Vuoi accedere rapidamente alle canzoni?</string>
  <string name="msg_widget_prompt_description">Aggiungi un bellissimo widget alla schermata Home.</string>
  <string name="msg_beat_mode_warning">Vuoi anche impostare la modalità beat a \"Solo suono\"?</string>

